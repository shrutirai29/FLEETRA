<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="view_fleetra_driver_list" model="ir.ui.view">
        <field name="name">fleetra.driver.list</field>
        <field name="model">fleetra.driver</field>

        <field name="arch" type="xml">
            <list string="Drivers">

                <field name="name"/>
                <field name="license_number"/>
                <field name="license_category"/>
                <field name="license_expiry_date"/>

                <field name="license_status"
                       widget="badge"
                       decoration-success="license_status == 'valid'"
                       decoration-warning="license_status == 'expiring'"
                       decoration-danger="license_status == 'expired'"/>

                <field name="safety_score"/>

                <field name="status"
                       widget="badge"
                       decoration-success="status == 'available'"
                       decoration-info="status == 'on_trip'"
                       decoration-warning="status == 'off_duty'"
                       decoration-danger="status == 'suspended'"/>

            </list>
        </field>
    </record>


    <record id="view_fleetra_driver_form" model="ir.ui.view">
        <field name="name">fleetra.driver.form</field>
        <field name="model">fleetra.driver</field>

        <field name="arch" type="xml">

            <form string="Driver">

                <sheet>

                    <div class="oe_title">
                        <label for="name"/>

                        <h1>
                            <field name="name"
                                   placeholder="Driver Name"/>
                        </h1>
                    </div>

                    <group>

                        <group string="Driver Information">

                            <field name="contact_number"/>

                            <field name="license_number"/>

                            <field name="license_category"/>

                            <field name="license_expiry_date"/>

                        </group>

                        <group string="Safety & Availability">

                            <field name="license_status"
                                   widget="badge"/>

                            <field name="safety_score"/>

                            <field name="status"
                                   widget="badge"/>

                        </group>

                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <record id="view_fleetra_driver_search" model="ir.ui.view">
        <field name="name">fleetra.driver.search</field>
        <field name="model">fleetra.driver</field>

        <field name="arch" type="xml">

            <search string="Search Drivers">

                <field name="name"/>
                <field name="license_number"/>

                <filter name="available"
                        string="Available"
                        domain="[('status', '=', 'available')]"/>

                <filter name="suspended"
                        string="Suspended"
                        domain="[('status', '=', 'suspended')]"/>

                <filter name="expired"
                        string="Expired License"
                        domain="[('license_status', '=', 'expired')]"/>

                <group expand="0" string="Group By">

                    <filter name="group_status"
                            string="Status"
                            context="{'group_by': 'status'}"/>

                    <filter name="group_license_category"
                            string="License Category"
                            context="{'group_by': 'license_category'}"/>

                </group>

            </search>

        </field>
    </record>


    <record id="action_fleetra_driver"
            model="ir.actions.act_window">

        <field name="name">Drivers</field>

        <field name="res_model">
            fleetra.driver
        </field>

        <field name="view_mode">
            list,form
        </field>

        <field name="search_view_id"
               ref="view_fleetra_driver_search"/>

    </record>

</odoo>