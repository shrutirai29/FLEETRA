<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="view_fleetra_fuel_log_list" model="ir.ui.view">
        <field name="name">fleetra.fuel.log.list</field>
        <field name="model">fleetra.fuel.log</field>

        <field name="arch" type="xml">
            <list string="Fuel Logs">
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <field name="liters"/>
                <field name="cost"/>
                <field name="fuel_efficiency"/>
            </list>
        </field>
    </record>

    <record id="view_fleetra_fuel_log_form" model="ir.ui.view">
        <field name="name">fleetra.fuel.log.form</field>
        <field name="model">fleetra.fuel.log</field>

        <field name="arch" type="xml">
            <form string="Fuel Log">

                <sheet>

                    <group>

                        <group string="Fuel Details">

                            <field name="vehicle_id"/>
                            <field name="trip_id"/>
                            <field name="liters"/>
                            <field name="date"/>

                        </group>

                        <group string="Cost & Efficiency">

                            <field name="cost"/>
                            <field name="currency_id"
                                   invisible="1"/>

                            <field name="fuel_efficiency"
                                   readonly="1"/>

                        </group>

                    </group>

                </sheet>

            </form>
        </field>
    </record>

    <record id="action_fleetra_fuel_log"
            model="ir.actions.act_window">

        <field name="name">Fuel Logs</field>
        <field name="res_model">fleetra.fuel.log</field>
        <field name="view_mode">list,form</field>

    </record>

</odoo>