<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- ===================================================== -->
    <!-- TRIP LIST VIEW -->
    <!-- ===================================================== -->

    <record id="view_fleetra_trip_list" model="ir.ui.view">
        <field name="name">fleetra.trip.list</field>
        <field name="model">fleetra.trip</field>

        <field name="arch" type="xml">

            <list string="Trip Dispatcher"
                  decoration-info="state == 'dispatched'"
                  decoration-success="state == 'completed'"
                  decoration-danger="state == 'cancelled'">

                <field name="name"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="cargo_weight"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="planned_distance"/>

                <field name="capacity_utilization"
                       widget="percentage"/>

                <field name="state"
                       widget="badge"
                       decoration-info="state == 'dispatched'"
                       decoration-success="state == 'completed'"
                       decoration-danger="state == 'cancelled'"/>

            </list>

        </field>
    </record>


    <!-- ===================================================== -->
    <!-- TRIP FORM VIEW -->
    <!-- ===================================================== -->

    <record id="view_fleetra_trip_form" model="ir.ui.view">
        <field name="name">fleetra.trip.form</field>
        <field name="model">fleetra.trip</field>

        <field name="arch" type="xml">

            <form string="Trip Dispatcher">

                <!-- HEADER -->

                <header>

                    <button name="action_dispatch"
                            string="Dispatch Trip"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>

                    <button name="action_complete"
                            string="Complete Trip"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'dispatched'"/>

                    <button name="action_cancel"
                            string="Cancel Trip"
                            type="object"
                            invisible="state not in ('draft', 'dispatched')"/>

                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,dispatched,completed,cancelled"/>

                </header>


                <!-- FORM BODY -->

                <sheet>

                    <!-- TITLE -->

                    <div class="oe_title">

                        <label for="name"/>

                        <h1>
                            <field name="name"
                                   readonly="state != 'draft'"
                                   placeholder="Trip Reference"/>
                        </h1>

                    </div>


                    <!-- ================================================= -->
                    <!-- MAIN TRIP INFORMATION -->
                    <!-- ================================================= -->

                    <group>

                        <!-- ROUTE INFORMATION -->

                        <group string="Route Information">

                            <field name="source"
                                   readonly="state != 'draft'"
                                   placeholder="Enter source location"/>

                            <field name="destination"
                                   readonly="state != 'draft'"
                                   placeholder="Enter destination location"/>

                            <field name="planned_distance"
                                   readonly="state != 'draft'"
                                   placeholder="Distance in KM"/>

                        </group>


                        <!-- DISPATCH ASSIGNMENT -->

                        <group string="Dispatch Assignment">

                            <field name="cargo_weight"
                                   readonly="state != 'draft'"
                                   placeholder="Enter cargo weight first"/>

                            <field name="vehicle_id"
                                   readonly="state != 'draft'"
                                   domain="[
                                       ('status', '=', 'available'),
                                       ('max_load_capacity', '>=', cargo_weight)
                                   ]"
                                   options="{
                                       'no_create': True,
                                       'no_create_edit': True
                                   }"/>

                            <field name="driver_id"
                                   readonly="state != 'draft'"
                                   domain="[
                                       ('status', '=', 'available')
                                   ]"
                                   options="{
                                       'no_create': True,
                                       'no_create_edit': True
                                   }"/>

                            <field name="capacity_utilization"
                                   widget="percentage"
                                   readonly="1"/>

                        </group>

                    </group>


                    <!-- ================================================= -->
                    <!-- ODOMETER INFORMATION -->
                    <!-- ================================================= -->

                    <group string="Odometer Information"
                           invisible="state == 'draft'">

                        <group>

                            <field name="current_odometer"
                                   readonly="1"/>

                            <field name="expected_final_odometer"
                                   readonly="1"/>

                        </group>

                        <group>

                            <field name="final_odometer"
                                   readonly="state == 'completed'"
                                   placeholder="Enter final odometer"/>

                        </group>

                    </group>


                    <!-- ================================================= -->
                    <!-- TRIP COMPLETION -->
                    <!-- ================================================= -->

                    <group string="Trip Completion"
                           invisible="state not in ('dispatched', 'completed')">

                        <group>

                            <field name="fuel_consumed"
                                   readonly="state == 'completed'"
                                   placeholder="Fuel consumed in litres"/>

                            <field name="fuel_cost"
                                   readonly="state == 'completed'"
                                   placeholder="Enter total fuel cost"/>

                        </group>


                        <group>

                            <field name="revenue"
                                   readonly="state == 'completed'"
                                   placeholder="Trip revenue"/>

                            <field name="currency_id"
                                   invisible="1"/>

                        </group>

                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <!-- ===================================================== -->
    <!-- TRIP SEARCH VIEW -->
    <!-- ===================================================== -->

    <record id="view_fleetra_trip_search" model="ir.ui.view">
        <field name="name">fleetra.trip.search</field>
        <field name="model">fleetra.trip</field>

        <field name="arch" type="xml">

            <search>

                <field name="name"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>

                <separator/>

                <!-- STATUS FILTERS -->

                <filter name="draft"
                        string="Draft"
                        domain="[('state', '=', 'draft')]"/>

                <filter name="dispatched"
                        string="Active Trips"
                        domain="[('state', '=', 'dispatched')]"/>

                <filter name="completed"
                        string="Completed"
                        domain="[('state', '=', 'completed')]"/>

                <filter name="cancelled"
                        string="Cancelled"
                        domain="[('state', '=', 'cancelled')]"/>

                <separator/>

                <!-- GROUP BY -->

                <filter name="group_state"
                        string="Status"
                        context="{'group_by': 'state'}"/>

                <filter name="group_vehicle"
                        string="Vehicle"
                        context="{'group_by': 'vehicle_id'}"/>

                <filter name="group_driver"
                        string="Driver"
                        context="{'group_by': 'driver_id'}"/>

            </search>

        </field>
    </record>


    <!-- ===================================================== -->
    <!-- TRIP WINDOW ACTION -->
    <!-- ===================================================== -->

    <record id="action_fleetra_trip"
            model="ir.actions.act_window">

        <field name="name">Trip Dispatcher</field>

        <field name="res_model">fleetra.trip</field>

        <field name="view_mode">list,form</field>

        <field name="search_view_id"
               ref="view_fleetra_trip_search"/>

        <field name="help" type="html">

            <p class="o_view_nocontent_smiling_face">
                Create your first transport trip
            </p>

            <p>
                Enter cargo weight, select a suitable vehicle
                and assign an available driver.
            </p>

        </field>

    </record>

</odoo>