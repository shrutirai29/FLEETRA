<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="view_fleetra_expense_list" model="ir.ui.view">
        <field name="name">fleetra.expense.list</field>
        <field name="model">fleetra.expense</field>

        <field name="arch" type="xml">

            <list string="Operational Expenses">

                <field name="date"/>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <field name="expense_type"/>
                <field name="amount"/>

            </list>

        </field>
    </record>


    <record id="view_fleetra_expense_form" model="ir.ui.view">
        <field name="name">fleetra.expense.form</field>
        <field name="model">fleetra.expense</field>

        <field name="arch" type="xml">

            <form string="Operational Expense">

                <sheet>

                    <div class="oe_title">

                        <h1>
                            <field name="name"
                                   placeholder="Expense Description"/>
                        </h1>

                    </div>

                    <group>

                        <group>

                            <field name="vehicle_id"/>
                            <field name="trip_id"/>
                            <field name="expense_type"/>

                        </group>

                        <group>

                            <field name="amount"/>
                            <field name="currency_id"
                                   invisible="1"/>
                            <field name="date"/>

                        </group>

                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <record id="action_fleetra_expense"
            model="ir.actions.act_window">

        <field name="name">Expenses</field>
        <field name="res_model">fleetra.expense</field>
        <field name="view_mode">list,form</field>

    </record>

</odoo>