<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="view_fleetra_maintenance_list" model="ir.ui.view">
        <field name="name">fleetra.maintenance.list</field>
        <field name="model">fleetra.maintenance</field>

        <field name="arch" type="xml">
            <list string="Maintenance">

                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="cost"/>

                <field name="state"
                       widget="badge"
                       decoration-warning="state == 'active'"
                       decoration-success="state == 'closed'"
                       decoration-danger="state == 'cancelled'"/>

            </list>
        </field>
    </record>


    <record id="view_fleetra_maintenance_form" model="ir.ui.view">
        <field name="name">fleetra.maintenance.form</field>
        <field name="model">fleetra.maintenance</field>

        <field name="arch" type="xml">

            <form string="Vehicle Maintenance">

                <header>

                    <button name="action_start_maintenance"
                            string="Start Maintenance"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>

                    <button name="action_close_maintenance"
                            string="Close Maintenance"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'active'"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state not in ('draft', 'active')"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,active,closed"/>

                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>

                        <group string="Maintenance Details">

                            <field name="vehicle_id"
                                   readonly="state != 'draft'"/>

                            <field name="service_type"
                                   readonly="state != 'draft'"/>

                            <field name="start_date"
                                   readonly="state != 'draft'"/>

                            <field name="description"
                                   readonly="state == 'closed'"/>

                        </group>

                        <group string="Cost & Status">

                            <field name="cost"
                                   readonly="state == 'closed'"/>

                            <field name="currency_id"
                                   invisible="1"/>

                            <field name="end_date"
                                   readonly="1"/>

                            <field name="state"
                                   widget="badge"
                                   readonly="1"/>

                        </group>

                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <record id="action_fleetra_maintenance"
            model="ir.actions.act_window">

        <field name="name">Maintenance</field>
        <field name="res_model">fleetra.maintenance</field>
        <field name="view_mode">list,form</field>

    </record>

</odoo>