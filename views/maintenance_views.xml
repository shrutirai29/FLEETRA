<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- ===================================================== -->
    <!-- MAINTENANCE LIST VIEW -->
    <!-- ===================================================== -->

    <record id="view_fleetra_maintenance_list" model="ir.ui.view">

        <field name="name">fleetra.maintenance.list</field>
        <field name="model">fleetra.maintenance</field>

        <field name="arch" type="xml">

            <list string="Vehicle Maintenance"
                  decoration-warning="state == 'active'"
                  decoration-success="state == 'closed'"
                  decoration-danger="state == 'cancelled'">

                <field name="name"/>

                <field name="vehicle_id"/>

                <field name="service_type"/>

                <field name="start_date"/>

                <field name="end_date"/>

                <field name="cost"/>

                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'active'"
                       decoration-success="state == 'closed'"
                       decoration-danger="state == 'cancelled'"/>

            </list>

        </field>

    </record>


    <!-- ===================================================== -->
    <!-- MAINTENANCE FORM VIEW -->
    <!-- ===================================================== -->

    <record id="view_fleetra_maintenance_form" model="ir.ui.view">

        <field name="name">fleetra.maintenance.form</field>
        <field name="model">fleetra.maintenance</field>

        <field name="arch" type="xml">

            <form string="Vehicle Maintenance">

                <!-- HEADER -->

                <header>

                    <button name="action_start_maintenance"
                            string="Start Maintenance"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>

                    <button name="action_close_maintenance"
                            string="Complete Maintenance"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'active'"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state not in ('draft', 'active')"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,active,closed,cancelled"/>

                </header>


                <!-- BODY -->

                <sheet>

                    <!-- TITLE -->

                    <div class="oe_title">

                        <label for="name"/>

                        <h1>
                            <field name="name"/>
                        </h1>

                    </div>


                    <!-- MAIN DETAILS -->

                    <group>

                        <group string="Maintenance Details">

                            <field name="vehicle_id"
                                   readonly="state != 'draft'"
                                   domain="[('status', '=', 'available')]"
                                   options="{
                                       'no_create': True,
                                       'no_create_edit': True
                                   }"/>

                            <field name="service_type"
                                   readonly="state != 'draft'"/>

                            <field name="start_date"
                                   readonly="state != 'draft'"/>

                        </group>


                        <group string="Maintenance Status">

                            <field name="state"
                                   widget="badge"
                                   readonly="1"/>

                            <field name="end_date"
                                   readonly="1"/>

                            <field name="currency_id"
                                   invisible="1"/>

                        </group>

                    </group>


                    <!-- SERVICE INFORMATION -->

                    <group string="Service Information">

                        <field name="description"
                               readonly="state in ('closed', 'cancelled')"
                               placeholder="Describe the service or repair performed..."/>

                    </group>


                    <!-- COST INFORMATION -->

                    <group string="Maintenance Cost"
                           invisible="state == 'draft'">

                        <field name="cost"
                               readonly="state in ('closed', 'cancelled')"
                               placeholder="Enter total maintenance cost"/>

                    </group>

                </sheet>

            </form>

        </field>

    </record>


    <!-- ===================================================== -->
    <!-- SEARCH VIEW -->
    <!-- ===================================================== -->

    <record id="view_fleetra_maintenance_search" model="ir.ui.view">

        <field name="name">fleetra.maintenance.search</field>
        <field name="model">fleetra.maintenance</field>

        <field name="arch" type="xml">

            <search>

                <field name="name"/>

                <field name="vehicle_id"/>

                <field name="service_type"/>

                <separator/>

                <filter name="draft"
                        string="Draft"
                        domain="[('state', '=', 'draft')]"/>

                <filter name="active"
                        string="In Progress"
                        domain="[('state', '=', 'active')]"/>

                <filter name="closed"
                        string="Completed"
                        domain="[('state', '=', 'closed')]"/>

                <filter name="cancelled"
                        string="Cancelled"
                        domain="[('state', '=', 'cancelled')]"/>

                <separator/>

                <filter name="group_state"
                        string="Status"
                        context="{'group_by': 'state'}"/>

                <filter name="group_vehicle"
                        string="Vehicle"
                        context="{'group_by': 'vehicle_id'}"/>

                <filter name="group_service_type"
                        string="Service Type"
                        context="{'group_by': 'service_type'}"/>

            </search>

        </field>

    </record>


    <!-- ===================================================== -->
    <!-- WINDOW ACTION -->
    <!-- ===================================================== -->

    <record id="action_fleetra_maintenance"
            model="ir.actions.act_window">

        <field name="name">Maintenance</field>

        <field name="res_model">
            fleetra.maintenance
        </field>

        <field name="view_mode">
            list,form
        </field>

        <field name="search_view_id"
               ref="view_fleetra_maintenance_search"/>

        <field name="help" type="html">

            <p class="o_view_nocontent_smiling_face">
                Create your first maintenance record
            </p>

            <p>
                Track vehicle servicing, workshop activity
                and maintenance costs.
            </p>

        </field>

    </record>

</odoo>